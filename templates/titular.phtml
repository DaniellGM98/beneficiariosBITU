			function getNutri(fk_inte){
				$.ajax({
					url: $apiUrl+'ficha_nutricion/getByTit/'+fk_inte,
					type: 'GET',
					dataType: 'json'
				}).done(function(resp) {
					if(!resp.response){
						Fnutri=true;
						//$("#nutriImc").val(resp.result.imc);
						Nutrilimpiar();
					}else{
						Nutrilimpiar();
						Fnutri=false;						
						$("#chkObes").val( ((resp.result.evaluacion_clinica).substring(0,1)=='S')
						? $("#chkObes").prop("checked", true) 
						: 0 );
						$("#chkDiab").val( ((resp.result.evaluacion_clinica).substring(1,2)=='S')
						? $("#chkDiab").prop("checked", true) 
						: 0 );
						$("#chkHiper").val( ((resp.result.evaluacion_clinica).substring(2,3)=='S')
						? $("#chkHiper").prop("checked", true) 
						: 0 );
						$("#chkCardi").val( ((resp.result.evaluacion_clinica).substring(3,4)=='S')
						? $("#chkCardi").prop("checked", true) 
						: 0 );
						$("#chkDisli").val( ((resp.result.evaluacion_clinica).substring(4,5)=='S')
						? $("#chkDisli").prop("checked", true) 
						: 0 );
						$("#chkCanc").val( ((resp.result.evaluacion_clinica).substring(5,6)=='S')
						? $("#chkCanc").prop("checked", true) 
						: 0 );
						$("#chkHema").val( ((resp.result.evaluacion_clinica).substring(6,7)=='S')
						? $("#chkHema").prop("checked", true) 
						: 0 );
						$("#chkRena").val( ((resp.result.evaluacion_clinica).substring(7,8)=='S')
						? $("#chkRena").prop("checked", true) 
						: 0 );
						$("#nutri-otro_clini").val((resp.result.evaluacion_clinica).substring(8));

						$("#chkTrau").val( ((resp.result.patologicos).substring(0,1)=='S')
						? $("#chkTrau").prop("checked", true) 
						: 0 );
						$("#chkCiru").val( ((resp.result.patologicos).substring(1,2)=='S')
						? $("#chkCiru").prop("checked", true) 
						: 0 );
						$("#chkGastr").val( ((resp.result.patologicos).substring(2,3)=='S')
						? $("#chkGastr").prop("checked", true) 
						: 0 );
						$("#chkInto").val( ((resp.result.patologicos).substring(3,4)=='S')
						? $("#chkInto").prop("checked", true) 
						: 0 );
						$("#chkInfec").val( ((resp.result.patologicos).substring(4,5)=='S')
						? $("#chkInfec").prop("checked", true) 
						: 0 );
						$("#pato-otro").val((resp.result.patologicos).substring(5));

						taba = (resp.result.tabaco).split(' ');
						if(taba.length>=3){
							$("#nutri-edadt").val( taba[0]);
							$("#nutri-cantt").val( taba[1]);
							$("#nutri-frect").val( taba[2]);
						}

						alco = (resp.result.alcohol).split(' ');
						if(alco.length>=3){
							$("#nutri-edada").val( alco[0]);
							$("#nutri-canta").val( alco[1]);
							$("#nutri-freca").val( alco[2]);
						}

						acti = (resp.result.actividad).split(' ');
						if(acti.length>=3){
							$("#nutri-edadf").val( acti[0]);
							$("#nutri-cantf").val( acti[1]);
							$("#nutri-frecf").val( acti[2]);
						}

						$("#nutri-glucosa").val(resp.result.glucosa);
						$("#nutri-trigli").val(resp.result.trigliceridos);
						$("#nutri-coles").val(resp.result.colesterol);
						$("#nutri-presion").val(resp.result.presion);
						$("#nutri-urea").val(resp.result.urea);
						$("#nutri-creati").val(resp.result.creatinina);
						$("#nutri-hemo").val(resp.result.hemoglobina);
						$("#nutri-otro_indicador").val(resp.result.otro_indicador);
						
						$("#nutri-comi-dia").val(resp.result.comidas_dia);

						$("#come-mis-hora").prop("checked", true); 
						
						$("#come-mis-hora").val( resp.result.comida_misma_hora=='1'
						? $("#come-mis-hora").prop("checked", true) 
						: $("#come-mis-hora").prop("checked", false) 
						);

						$("#comi-donde").val(resp.result.comida_donde);

						$("#comi-alerg").val(resp.result.comida_alergia);
						
						$("#nutri-observaciones").val(resp.result.observaciones);

						$("#nutri-peso").val(resp.result.peso);
						
						$("#nutri-talla").val(resp.result.talla);

						$("#nutri-cintura").val(resp.result.cintura);

						$("#nutriImc").val(resp.result.imc);
						
					}
				});
			}

