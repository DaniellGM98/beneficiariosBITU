			function getItems() { 
				var $integ=0;
				blockPage();
				cleanTable('tbl-items');
				$('#tbl-items tbody').empty();
				$('#nutri-fk_integrante').empty();
				$('#nutri-fk_integrante').append('<option value="<?= $info->id_integrante ?>" data-edad="<?= $info->edad ?>" data-sexo="<?= $info->sexo ?>"><?= $info->nombre.' '.$info->apaterno.' '.$info->amaterno ?></option>');
				$.get($apiUrl+'integrante/getByTit/<?= $info->id_titular ?>', function(resp) {
					$.each(resp.result, function(index, item) { 
						addItemRow(item); 
						if(item.estatus=="1") $integ++;
					});
					$integ++;
					$('.ficha-inte').html($integ);
					$.unblockUI();
				});
			}

			function addItemRow(item) {
