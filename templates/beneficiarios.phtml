			$('#chk-all').click(function(){
				if($(this).is(':checked')){
					$('#grid-fields').empty();
					$('[name="chk-campo"]').prop('checked', false).trigger('click');
				}else{
					$('[name="chk-campo"]').trigger('click');
				}
			});

			$('[name="chk-campo"]').click(function(){
				f = $(this).val();
				if($(this).is(':checked')){
					item = $('<div class="grid-item">'+f+'</div>');
					$('#grid-fields').append(item);
				}else{
					$('#chk-all').prop('checked', false);
					$.each($('.grid-item'), function (ind, elem) { 
						if($(elem).text() == f) { $(elem).remove(); return false; }
					});
				}
			});

			$('#btnExportar').click(function(){
				$('.invalid-tooltip').remove();
				campos = [];
				$.each($('.grid-item'), function (ind, elem) { 
					campos.push($(elem).text());
				});
				if(campos.length == 0){
					$errLabel = $('<div class="invalid-tooltip"></div>');
					$errLabel.html('Debe seleccionar al menos un campo');
					$('#btnExportar').after($errLabel);
					$errLabel.show();
				}else{
					swal({ type:"success", title:"Exportando a Excel", text:"El proceso de Exportación puede demorar varios minutos. Por favor sea paciente hasta que se complete el proceso.", timer:6000 });
					window.open('<?= URL_ROOT ?>/titular/getExcel/'+campos.toString())
				}
			});

			function LimpiarSalario(){
				$("#item-salario").val("");
				$("#item-limitesal").val("");
			}

			function getSalario(){
				$.ajax({
					url: $apiUrl+'titular/getSalario/',
					type: 'GET',
					dataType: 'json'
				}).done(function(resp) {
					if(!resp.response){
						LimpiarSalario();
					}else{
						LimpiarSalario();
						$("#item-salario").val(resp.result.salario_minimo);
						$("#item-limitesal").val(resp.result.limite_salarial);
						// document.getElementById('parti-nomcomp').innerHTML= resp.result.nombre+" "+resp.result.paterno+" "+resp.result.materno;
					}
				});
			}

