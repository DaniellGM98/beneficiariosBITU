			$('#btnSave').click(function() {
				$('.invalid-tooltip').remove();
				data = {};

				salari = parseFloat(document.getElementById('item-salario').value);
				limitsalari = parseFloat(document.getElementById('item-limitesal').value);
				data["salario_minimo"] = salari.toFixed(2);
				data["limite_salarial"] = limitsalari.toFixed(2);

				$errLabel = $('<div class="invalid-tooltip"></div>');
				if(document.getElementById('item-salario').value == '') {
					$errLabel.html('Debe ingresar el Salario Mínimo');
					$('#item-salario').focus().after($errLabel);
					$errLabel.show();
				}else if(document.getElementById('item-limitesal').value == '') {
					$errLabel.html('Debe ingresar el Límite salarial');
					$('#item-limitesal').focus().after($errLabel);
					$errLabel.show();
				} else {
					blockPage();
					$.ajax({
						type: 'PUT',
						url: $apiUrl+'titular/editSalario/',
						data: data,
						dataType: "json",
						success: function (resp) {
							if(resp.response){
								$('#frm-salario').modal('hide');
								swal({ type: "success", title: "¡Listo!", text: "Se guardaron los datos correctamente.", timer: 4000 });
							}else{
								swal({ type: "warning", title: "Oops!", text: resp.message, timer: 4000 }); 
							}
							$.unblockUI();
						}
					});
				}
			});
		});
